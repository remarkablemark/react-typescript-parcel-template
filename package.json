{
  "name": "react-typescript-parcel-template",
  "version": "1.0.0-alpha",
  "description": "React TypeScript Parcel Template",
  "author": "Mark <mark@remarkablemark.org>",
  "source": "public/index.html",
  "scripts": {
    "build": "parcel build",
    "clean": "rm -rf .parcel-cache dist",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "husky",
    "start": "parcel --open",
    "tsc": "tsc --noEmit"
  },
  "homepage": "https://remarkablemark.org/react-typescript-parcel-template/",
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@parcel/packager-raw-url": "2.16.4",
    "@parcel/transformer-webmanifest": "2.16.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "eslint": "10.4.0",
    "eslint-plugin-prettier": "5.5.6",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "parcel": "2.16.4",
    "prettier": "3.8.3",
    "process": "0.11.10",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "5.9.3"
  },
  "private": true,
  "license": "MIT"
}
